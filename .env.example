# Deleveraging Watch — environment.
# Copy to `.env` and fill in. The app reads `.env` at startup via python-dotenv.
# Phase 0 runs with NO keys set (stub adapter, console notifier). Keys are
# wired in as later phases come online; Settings (§11.E) shows presence/absence.

# --- Core market data (Phase 1) ---
# Massive Stocks Advanced. Legacy POLYGON_API_KEY is accepted as an alias.
MASSIVE_API_KEY=

# --- Reference + earnings (Phase 2) ---
FINNHUB_API_KEY=

# --- Profile-text generation, monthly (Phase 2) ---
ANTHROPIC_API_KEY=

# --- Curated X account polling (Phase 2) ---
X_BEARER_TOKEN=

# --- Pushover notifications (Phase 1) ---
# One User Key, four App Tokens (one per icon: critical / warn / news / info).
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN_CRITICAL=
PUSHOVER_APP_TOKEN_WARN=
PUSHOVER_APP_TOKEN_NEWS=
PUSHOVER_APP_TOKEN_INFO=

# --- App config ---
DW_DB_PATH=deleveraging_watch.db
DW_HOST=127.0.0.1
DW_PORT=5000
# 'stub' (Phase 0, synthetic data) or 'massive' (Phase 1+, needs MASSIVE_API_KEY).
DW_DATA_ADAPTER=stub
# 'console' (Phase 0) or 'pushover' (Phase 1, needs Pushover tokens).
DW_NOTIFIER=console
